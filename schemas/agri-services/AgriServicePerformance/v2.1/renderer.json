{
  "schema": "AgriServicePerformance",
  "version": "2.1.0",
  "card_template": "{{livestockCount}} {{livestockType}} | {{farmLocation.village}}, {{farmLocation.county}} | {{confirmedAppointmentTime}}",
  "detail_template": "Appointment: {{confirmedAppointmentTime}}\nLivestock: {{livestockCount}} {{livestockType}}\nFarm: {{farmLocation.village}}, {{farmLocation.ward}}, {{farmLocation.county}}\nCoordinates: {{#if farmLocation.geo}}{{farmLocation.geo.coordinates.[0]}}, {{farmLocation.geo.coordinates.[1]}}{{/if}}\nCompletion: {{#if providerConfirmedCompletion}}Confirmed{{else}}Pending{{/if}}",
  "html": "<div class=\"agri-service-performance-card\" data-performance-id=\"{{beckn:id}}\"><span class=\"livestock\">{{beckn:performanceAttributes.livestockCount}} {{beckn:performanceAttributes.livestockType}}</span><address>{{beckn:performanceAttributes.farmLocation.village}}, {{beckn:performanceAttributes.farmLocation.county}}</address><time>{{beckn:performanceAttributes.confirmedAppointmentTime}}</time></div>",
  "html_detail": "<div class=\"agri-service-performance-detail\" data-performance-id=\"{{beckn:id}}\"><h3>Service Delivery Details</h3><dl><dt>Appointment</dt><dd>{{beckn:performanceAttributes.confirmedAppointmentTime}}</dd><dt>Livestock</dt><dd>{{beckn:performanceAttributes.livestockCount}} {{beckn:performanceAttributes.livestockType}}</dd><dt>Farm Location</dt><dd>{{beckn:performanceAttributes.farmLocation.village}}, {{beckn:performanceAttributes.farmLocation.ward}}<br/>{{beckn:performanceAttributes.farmLocation.county}}, {{beckn:performanceAttributes.farmLocation.country}}</dd>{{#if beckn:performanceAttributes.farmLocation.geo}}<dt>Coordinates</dt><dd>{{beckn:performanceAttributes.farmLocation.geo.coordinates.[0]}}, {{beckn:performanceAttributes.farmLocation.geo.coordinates.[1]}}</dd>{{/if}}{{#if beckn:performanceAttributes.farmLocation.locationLandmark}}<dt>Landmark</dt><dd>{{beckn:performanceAttributes.farmLocation.locationLandmark}}</dd>{{/if}}<dt>Provider Confirmed</dt><dd>{{#if beckn:performanceAttributes.providerConfirmedCompletion}}Yes{{else}}No{{/if}}</dd><dt>Client Confirmed</dt><dd>{{#if beckn:performanceAttributes.clientConfirmedCompletion}}Yes{{else}}No{{/if}}</dd>{{#if beckn:performanceAttributes.serviceNotes}}<dt>Service Notes</dt><dd>{{beckn:performanceAttributes.serviceNotes}}</dd>{{/if}}{{#if beckn:performanceAttributes.followUpRequired}}<dt>Follow-up Date</dt><dd>{{beckn:performanceAttributes.followUpDate}}</dd>{{/if}}</dl></div>"
}
