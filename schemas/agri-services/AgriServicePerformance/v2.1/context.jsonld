{
  "@context": {
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/",
    "aspm": "https://schema.beckn.io/AgriServicePerformance#",
    "spm": "https://schema.beckn.io/ServicePerformance#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",

    "AgriServicePerformance": "aspm:AgriServicePerformance",

    "appointmentWindowStart": {"@id": "spm:appointmentWindowStart"},
    "appointmentWindowEnd": {"@id": "spm:appointmentWindowEnd"},
    "confirmedAppointmentTime": {"@id": "spm:confirmedAppointmentTime"},
    "serviceLocation": {"@id": "spm:serviceLocation"},
    "providerConfirmedCompletion": {"@id": "spm:providerConfirmedCompletion"},
    "clientConfirmedCompletion": {"@id": "spm:clientConfirmedCompletion"},
    "serviceNotes": {"@id": "spm:serviceNotes"},
    "followUpRequired": {"@id": "spm:followUpRequired"},
    "followUpDate": {"@id": "spm:followUpDate"},
    "AgriFarmLocation": "aspm:AgriFarmLocation",
    "AgriLivestockType": "aspm:AgriLivestockType",

    "farmLocation": {"@id": "aspm:farmLocation"},
    "livestockCount": {"@id": "aspm:livestockCount"},
    "livestockType": {"@id": "aspm:livestockType"},
    "village": {"@id": "aspm:village"},
    "ward": {"@id": "aspm:ward"},
    "county": {"@id": "aspm:county"},
    "country": {"@id": "aspm:country"},
    "geo": {"@id": "aspm:geo"},
    "coordinates": {"@id": "aspm:coordinates", "@container": "@list"},
    "locationLandmark": {"@id": "aspm:locationLandmark"}
  }
}
