  "@graph": [
    {
      "@id": "awr:AgriWeatherResource",
      "@type": "rdfs:Class",
      "rdfs:label": "AgriWeatherResource",
      "rdfs:comment": "A Beckn resource representing a meteorological data service that delivers weather forecasts, nowcasts, or interpreted agro-meteorological advisories to farmers and Seeker NPs. Weather parameters are expressed as coded values referencing WMO BUFR or CF Convention vocabularies and are not enumerated in this schema."
    }
  ]
