{
  "@context": {
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/",
    "asof": "https://schema.beckn.io/AgriServiceOffer#",
    "sof": "https://schema.beckn.io/ServiceOffer#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",

    "AgriServiceOffer": "asof:AgriServiceOffer",

    "minimumQuantity": {"@id": "sof:minimumQuantity"},
    "maximumQuantity": {"@id": "sof:maximumQuantity"},
    "requiresAdvanceBooking": {"@id": "sof:requiresAdvanceBooking"},
    "cancellationPolicies": {"@id": "sof:cancellationPolicies", "@container": "@list"},
    "hoursBeforeService": {"@id": "sof:hoursBeforeService"},
    "refundFraction": {"@id": "sof:refundFraction"},
    "cancellationPolicyDescription": {"@id": "sof:cancellationPolicyDescription"},
    "eligibilityCriteria": {"@id": "sof:eligibilityCriteria", "@container": "@list"},
    "validityPeriodDays": {"@id": "sof:validityPeriodDays"},
    "bulkDiscountAvailable": {"@id": "sof:bulkDiscountAvailable"},

    "inputBrandOrVariety": {"@id": "asof:inputBrandOrVariety"}
  }
}
